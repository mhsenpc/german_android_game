                    </androidx.constraintlayout.widget.ConstraintLayout>
                </FrameLayout>
            </LinearLayout>

            <!-- ===== ROW 2 (RTL: Frankfurt · Cologne · Düsseldorf) ===== -->
            <LinearLayout
