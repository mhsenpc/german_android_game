<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Three-bar German flag accent strip -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/germany_black" />
            <corners android:radius="2dp" />
            <size android:width="48dp" android:height="4dp" />
        </shape>
    </item>
    <item android:top="6dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/germany_red" />
            <corners android:radius="2dp" />
            <size android:width="48dp" android:height="4dp" />
        </shape>
    </item>
    <item android:top="12dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/germany_gold" />
            <corners android:radius="2dp" />
            <size android:width="48dp" android:height="4dp" />
        </shape>
    </item>
</layer-list>
